#!/bin/bash

DOTFILES_CLAUDE="$HOME/dotfiles/claude"
CLAUDE="$HOME/.claude"

mkdir -p "$CLAUDE"

# Skills: always symlink so skills are shared across all machines
if [ -L "$CLAUDE/skills" ]; then
	echo "Claude skills symlink already exists ✅"
elif [ -d "$CLAUDE/skills" ]; then
	echo "Moving existing skills into dotfiles..."
	cp -r "$CLAUDE/skills/." "$DOTFILES_CLAUDE/skills/"
	rm -rf "$CLAUDE/skills"
	ln -s "$DOTFILES_CLAUDE/skills" "$CLAUDE/skills"
	echo "Claude skills symlinked ✅"
else
	ln -s "$DOTFILES_CLAUDE/skills" "$CLAUDE/skills"
	echo "Claude skills symlinked ✅"
fi

# Settings: symlink to work settings if present, otherwise universal
if [ -f "$DOTFILES_CLAUDE/settings.work.json" ]; then
	TARGET="$DOTFILES_CLAUDE/settings.work.json"
else
	TARGET="$DOTFILES_CLAUDE/settings.json"
fi

if [ -L "$CLAUDE/settings.json" ] && [ "$(readlink "$CLAUDE/settings.json")" = "$TARGET" ]; then
	echo "Claude settings.json already symlinked ✅"
else
	ln -sf "$TARGET" "$CLAUDE/settings.json"
	echo "Claude settings.json symlinked → $(basename "$TARGET") ✅"
fi
