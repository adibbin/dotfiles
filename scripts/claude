#!/bin/bash

DOTFILES_CLAUDE="$HOME/dotfiles/claude"
CLAUDE="$HOME/.claude"

mkdir -p "$CLAUDE"

# Skills: always symlink so skills are shared across all machines
if [ -L "$CLAUDE/skills" ]; then
	echo "Claude skills symlink already exists ✅"
elif [ -d "$CLAUDE/skills" ]; then
	echo "Moving existing skills into dotfiles..."
	cp -r "$CLAUDE/skills/." "$DOTFILES_CLAUDE/skills/"
	rm -rf "$CLAUDE/skills"
	ln -s "$DOTFILES_CLAUDE/skills" "$CLAUDE/skills"
	echo "Claude skills symlinked ✅"
else
	ln -s "$DOTFILES_CLAUDE/skills" "$CLAUDE/skills"
	echo "Claude skills symlinked ✅"
fi

# Settings: symlink to personal settings
ln -sf "$DOTFILES_CLAUDE/settings.json" "$CLAUDE/settings.json"
echo "Claude settings.json symlinked ✅"
